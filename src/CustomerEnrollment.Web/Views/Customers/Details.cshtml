@model CustomerView
@{ ViewData["Title"] = "Customer Details"; }

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                Customer #@Model.CustomerId
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Name</dt>
                    <dd class="col-sm-9">@Model.Name</dd>

                    <dt class="col-sm-3">Mobile</dt>
                    <dd class="col-sm-9">@Model.Mobile</dd>

                    <dt class="col-sm-3">Email</dt>
                    <dd class="col-sm-9">@Model.Email</dd>

                    <dt class="col-sm-3">Proof Type</dt>
                    <dd class="col-sm-9">@Model.ProofType</dd>

                    <dt class="col-sm-3">Proof Ref</dt>
                    <dd class="col-sm-9">@Model.ProofRef</dd>

                    <dt class="col-sm-3">Address</dt>
                    <dd class="col-sm-9">@Model.Address</dd>

                    <dt class="col-sm-3">Created (UTC)</dt>
                    <dd class="col-sm-9">@Model.CreatedOnUtc.ToString("u")</dd>
                </dl>
            </div>
        </div>
        <a class="btn btn-outline-secondary mt-3" asp-action="Search">Back to search</a>
    </div>
</div>
