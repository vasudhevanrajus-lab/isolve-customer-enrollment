@model EnrollResultViewModel
@{ ViewData["Title"] = "Enrolled"; }

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="alert alert-success">
            <h5 class="alert-heading">Success</h5>
            <p class="mb-1">@Model.Message</p>
            <hr />
            <p class="mb-0"><strong>Customer ID:</strong> @Model.CustomerId</p>
        </div>
        <a class="btn btn-outline-primary" asp-action="Details" asp-route-id="@Model.CustomerId">View details</a>
        <a class="btn btn-outline-secondary" asp-action="Enroll">Enroll another</a>
    </div>
</div>
